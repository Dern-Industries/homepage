---
const year = new Date().getFullYear();
const contactEmail = 'press@dernindustries.com'; // TODO: replace with real address
const socials = [
  { label: 'GitHub', href: 'https://github.com/' }, // TODO: replace
];
---

<footer id="contact" class="relative z-10 border-t border-ink-600 bg-ink-950/60 px-6 py-16 md:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <img src="/logo-full.png" alt="Dern Industries" class="-ml-2 w-40" />
      </div>

      <div>
        <p class="hud-label">Contact</p>
        <a
          href={`mailto:${contactEmail}`}
          class="mt-3 inline-block font-mono text-sm text-smoke-200 transition-colors hover:text-orange"
        >
          {contactEmail}
        </a>
      </div>

      <div>
        <p class="hud-label">Connect</p>
        <ul class="mt-3 space-y-2">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-sm text-smoke-200 transition-colors hover:text-orange"
              >
                {s.label} <span class="text-smoke-500">&#8599;</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-3 border-t border-ink-700 pt-6 font-mono text-[0.7rem] uppercase tracking-widest2 text-smoke-500 md:flex-row md:items-center">
      <span>&copy; {year} Dern Industries LLC. All rights reserved.</span>
    </div>
  </div>
</footer>
