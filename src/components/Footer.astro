---
const year = new Date().getFullYear();
const contactEmail = 'contact@dernindustries.com';
const socials = [
  { label: 'GitHub', href: 'https://github.com/Dern-Industries' },
];
---

<footer id="contact" class="relative z-10 border-t border-ink-600 bg-ink-950/60 px-6 py-10 md:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <img src="/logo-full.png" alt="Dern Industries" class="-ml-2 w-32" />

      <a
        href={`mailto:${contactEmail}`}
        class="font-mono text-sm text-smoke-200 transition-colors hover:text-orange"
      >
        {contactEmail}
      </a>

      <div class="flex flex-wrap items-center justify-end gap-6 font-mono text-sm text-smoke-200">
        {socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-orange"
          >
            {s.label} <span class="text-smoke-500">&#8599;</span>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-8 border-t border-ink-700 pt-5 font-mono text-[0.7rem] uppercase tracking-widest2 text-smoke-500">
      <span>&copy; {year} Dern Industries LLC. All rights reserved.</span>
    </div>
  </div>
</footer>
