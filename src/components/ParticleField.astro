---
// Subtle drifting dust / starfield background. Tiny particles float slowly and
// twinkle, with no grid or cursor gimmicks. Pauses on tab hide and renders a
// static frame for reduced-motion users.
---

<canvas
  id="particle-field"
  class="pointer-events-none fixed inset-0 -z-10 h-full w-full"
  aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById('particle-field') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d', { alpha: true })!;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const ORANGE = '249, 115, 22';
    const WHITE = '245, 245, 244';

    let width = 0;
    let height = 0;
    let dpr = 1;
    let time = 0;

    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      color: string;
      twinkleSpeed: number;
      twinkleOffset: number;
      alpha: number;
    }

    let particles: Particle[] = [];

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = window.innerWidth;
      height = window.innerHeight;
      canvas!.width = width * dpr;
      canvas!.height = height * dpr;
      canvas!.style.width = width + 'px';
      canvas!.style.height = height + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function seedParticles() {
      particles = [];
      const count = Math.min(110, Math.floor((width * height) / 12000));
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 0.18,
          vy: (Math.random() - 0.5) * 0.18,
          size: Math.random() < 0.8 ? 1 + Math.random() * 0.9 : 1.6 + Math.random() * 0.9,
          color: Math.random() < 0.75 ? ORANGE : WHITE,
          twinkleSpeed: 0.0005 + Math.random() * 0.0015,
          twinkleOffset: Math.random() * Math.PI * 2,
          alpha: 0.2 + Math.random() * 0.3,
        });
      }
    }

    function drawParticles() {
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;

        if (p.x < -12) p.x = width + 12;
        if (p.x > width + 12) p.x = -12;
        if (p.y < -12) p.y = height + 12;
        if (p.y > height + 12) p.y = -12;

        const twinkle = 0.5 + Math.sin(time * p.twinkleSpeed + p.twinkleOffset) * 0.5;
        const alpha = p.alpha * (0.5 + twinkle * 0.5);

        if (p.size > 1.4) {
          ctx.shadowBlur = 6;
          ctx.shadowColor = `rgba(${p.color}, 0.45)`;
        } else {
          ctx.shadowBlur = 0;
        }

        ctx.fillStyle = `rgba(${p.color}, ${alpha})`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.shadowBlur = 0;
    }

    let running = true;
    function frame(now: number) {
      if (!running) return;
      time = now;
      ctx.clearRect(0, 0, width, height);
      drawParticles();
      requestAnimationFrame(frame);
    }

    function renderStatic() {
      ctx.clearRect(0, 0, width, height);
      drawParticles();
    }

    window.addEventListener('resize', () => {
      resize();
      seedParticles();
      if (reduceMotion) renderStatic();
    });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        running = false;
      } else if (!reduceMotion) {
        running = true;
        frame(performance.now());
      }
    });

    resize();
    seedParticles();
    if (reduceMotion) {
      renderStatic();
    } else {
      frame(performance.now());
    }
  }
</script>
