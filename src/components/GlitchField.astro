<canvas
  id="glitch-field"
  class="pointer-events-none absolute inset-0 z-0 h-full w-full"
  aria-hidden="true"
></canvas>

<script>
  (function () {
    const canvas = document.getElementById('glitch-field');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      canvas.width = Math.max(1, Math.floor(rect.width));
      canvas.height = Math.max(1, Math.floor(rect.height));
      return { width: canvas.width, height: canvas.height };
    };

    let { width, height } = resize();
    const COUNT = 12;
    const motes = [];
    let time = 0;

    const random = (min, max) => Math.random() * (max - min) + min;

    const createMote = () => {
      const type = Math.random() < 0.5 ? 'dash' : 'block';
      return {
        type,
        x: random(0, width),
        y: random(0, height),
        vx: random(-0.15, 0.15),
        vy: random(-0.1, 0.1),
        w: type === 'dash' ? random(12, 34) : random(3, 10),
        h: type === 'dash' ? random(1, 2) : random(3, 10),
        opacity: 0,
        targetOpacity: random(0.14, 0.32),
        life: 0,
        maxLife: random(800, 2200),
        phase: 'in',
        driftAngle: random(0, Math.PI * 2),
        driftRadius: random(2, 8),
      };
    };

    for (let i = 0; i < COUNT; i++) motes.push(createMote());

    const drawMote = (m) => {
      const alpha = Math.max(0, m.opacity);
      const driftX = Math.sin(time * 0.0008 + m.driftAngle) * m.driftRadius;
      const driftY = Math.cos(time * 0.0008 + m.driftAngle) * m.driftRadius;
      ctx.fillStyle = `rgba(249, 115, 22, ${alpha})`;
      ctx.fillRect(m.x + driftX, m.y + driftY, m.w, m.h);
    };

    const update = () => {
      time += 16;
      ctx.clearRect(0, 0, width, height);

      for (const m of motes) {
        m.x += m.vx;
        m.y += m.vy;
        m.life += 16;

        if (m.x < -20) m.x = width + 20;
        if (m.x > width + 20) m.x = -20;
        if (m.y < -20) m.y = height + 20;
        if (m.y > height + 20) m.y = -20;

        if (m.phase === 'in') {
          m.opacity += (m.targetOpacity - m.opacity) * 0.08;
          if (m.opacity >= m.targetOpacity * 0.92) m.phase = 'hold';
        } else if (m.phase === 'hold') {
          if (m.life > m.maxLife * 0.5) m.phase = 'out';
        } else if (m.phase === 'out') {
          m.opacity *= 0.92;
          if (m.opacity < 0.005) Object.assign(m, createMote());
        }

        drawMote(m);
      }

      requestAnimationFrame(update);
    };

    window.addEventListener('resize', () => {
      ({ width, height } = resize());
    });

    if (!reduceMotion) requestAnimationFrame(update);
  })();
</script>
