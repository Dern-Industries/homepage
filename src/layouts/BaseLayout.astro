---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dern Industries',
  description = 'Dern Industries — an umbrella holding company for a wide range of side projects and ventures. Retro-futuristic, industrial, and built to last.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://dernindustries.com');
const ogImage = new URL('/og-image.svg', Astro.site ?? 'https://dernindustries.com');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Dern Industries',
  url: 'https://dernindustries.com',
  logo: 'https://dernindustries.com/logo-full.png',
  description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <meta name="theme-color" content="#050506" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Dern Industries" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="relative overflow-x-hidden">
    <slot />
  </body>
</html>
